{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AuraScholar",
  "version": "0.0.1",
  "identifier": "app.aurascholar.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AuraScholar",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
