{
  "name": "aurascholar",
  "private": true,
  "version": "0.0.1",
  "description": "Open-source research companion for early-career researchers: reference management, indexing sentinel, and academic homepage.",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
